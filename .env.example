# Bond waitlist — Supabase connection.
#
# These two values are SAFE to be public (the publishable key only allows
# INSERT into bond_waitlist via row-level security — it cannot read the list).
# They are committed as defaults in lib/config.ts so the site works on Vercel
# with zero configuration. Set them here / in Vercel only if you want to point
# the form at a different Supabase project.

SUPABASE_URL=https://rulvofxdcyojtzpxnoru.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_L62hdz-9-HijQA2P6TWQPA_H_ZOvxL9

# Optional: get an email when someone joins the waitlist (via Resend).
# Sign up free at https://resend.com, create an API key, and set it here / in
# Vercel. Without this key, signups still save but no notification is sent.
RESEND_API_KEY=
# Where the "new signup" alert is sent, and who it's from. The default from
# address works without verifying a domain, as long as NOTIFY_TO is the email
# you used to sign up for Resend.
NOTIFY_TO=rossdelport1998@gmail.com
NOTIFY_FROM=Bond waitlist <onboarding@resend.dev>
